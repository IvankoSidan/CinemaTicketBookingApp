<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/introFragment">

    <!-- Intro -->
    <fragment
        android:id="@+id/introFragment"
        android:name="com.artur.cinematicketbooking.presentation.fragments.IntroFragment"
        android:label="Intro"
        tools:layout="@layout/activity_intro">
        <action
            android:id="@+id/action_introFragment_to_authFragment"
            app:destination="@id/authFragment" />
    </fragment>

    <!-- Auth -->
    <fragment
        android:id="@+id/authFragment"
        android:name="com.artur.cinematicketbooking.presentation.fragments.AuthFragment"
        android:label="Auth"
        tools:layout="@layout/fragment_auth">
        <action
            android:id="@+id/action_authFragment_to_explorerFragment"
            app:destination="@id/explorerFragment" />
    </fragment>

    <!-- Explorer -->
    <fragment
        android:id="@+id/explorerFragment"
        android:name="com.artur.cinematicketbooking.presentation.fragments.ExplorerFragment"
        android:label="Explorer"
        tools:layout="@layout/fragment_explorer">
        <action
            android:id="@+id/action_explorerFragment_to_filmDetailsFragment"
            app:destination="@id/filmDetailsFragment" />
    </fragment>

    <!-- Cart -->
    <fragment
        android:id="@+id/cartFragment"
        android:name="com.artur.cinematicketbooking.presentation.fragments.CartFragment"
        android:label="Cart"
        tools:layout="@layout/fragment_cart" />

    <!-- Profile -->
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.artur.cinematicketbooking.presentation.fragments.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile">

        <!-- Навигация к FragmentNotifications без параметров -->
        <action
            android:id="@+id/profileFragment_to_fragmentNotifications"
            app:destination="@id/fragmentNotifications" />
    </fragment>

    <!-- Fragment Notifications -->
    <fragment
        android:id="@+id/fragmentNotifications"
        android:name="com.artur.cinematicketbooking.presentation.fragments.FragmentNotifications"
        android:label="Notifications"
        tools:layout="@layout/fragment_notifications" />

    <!-- Film Details -->
    <fragment
        android:id="@+id/filmDetailsFragment"
        android:name="com.artur.cinematicketbooking.presentation.fragments.FragmentFilmDetails"
        android:label="Film Details"
        tools:layout="@layout/fragment_film_details" />

    <action
        android:id="@+id/action_profileFragment_to_fragmentNotifications"
        app:destination="@id/fragmentNotifications" />
</navigation>
